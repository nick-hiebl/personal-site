---
import { getCollection } from 'astro:content'

import { Game } from '../../content/games/number-match'
import GameLayout from '../../layouts/Game.astro'

const games = await getCollection('games')

const game = games.find(game => game.data.gameId === 'number-match')!
---
<GameLayout {...game.data}>
	<Game client:only />
</GameLayout>
