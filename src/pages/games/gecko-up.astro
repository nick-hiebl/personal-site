---
import { getCollection } from 'astro:content'

import { Game } from '../../content/games/gecko-up'
import GameLayout from '../../layouts/Game.astro'

const games = await getCollection('games')

const game = games.find(game => game.data.gameId === 'gecko-up')!
---
<GameLayout {...game.data}>
	<Game client:only />
</GameLayout>
